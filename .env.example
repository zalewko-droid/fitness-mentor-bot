# =============================================================================
# AI Fitness Mentor — переменные окружения
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env
# =============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
# Получи у @BotFather командой /newbot
BOT_TOKEN=

# ── Groq ──────────────────────────────────────────────────────────────────────
# Получи на: console.groq.com/keys (бесплатный tier есть)
GROQ_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Найди в: Supabase Dashboard → Settings → API
# ВАЖНО: используй service_role key (не anon), чтобы обойти RLS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# ── Obsidian Sync (локальный сервер на Lenovo) ────────────────────────────────
# URL Cloudflare Tunnel до obsidian_sync/main.py
# Получи через: cloudflared tunnel --url http://localhost:8000
OBSIDIAN_SYNC_URL=https://your-tunnel.trycloudflare.com

# ── Telegram Mini App ─────────────────────────────────────────────────────────
# URL GitHub Pages где хостится tma/index.html
# Настрой через: Telegram BotFather → /newapp
TMA_URL=https://yourusername.github.io/fitness-mentor-tma
